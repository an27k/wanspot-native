# AdMob 広告ユニット ID（本番・カスタム枠）。未設定時はデモ ID または既存のネイティブ枠にフォールバック
# EXPO_PUBLIC_ADMOB_IOS_NATIVE_AD_UNIT_ID=
# EXPO_PUBLIC_ADMOB_ANDROID_NATIVE_AD_UNIT_ID=
# EXPO_PUBLIC_ADMOB_IOS_VIDEO_NATIVE_AD_UNIT_ID=
# EXPO_PUBLIC_ADMOB_ANDROID_VIDEO_NATIVE_AD_UNIT_ID=

# Google Static Maps（AI プラン結果のルート表示）。Places と同じキーで可。Static Maps API を有効化すること。
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# API ベースURL（未設定時は https://wanspot.app）
EXPO_PUBLIC_API_BASE_URL=https://wanspot.app

# アプリ（表示用・参加費文言の % と揃える）
EXPO_PUBLIC_PLATFORM_FEE_PERCENT=0

# Next.js バックエンド（wanspot.app）側の .env にも同値を置く:
# PLATFORM_FEE_PERCENT=0
#
# Stripe Connect 戻り先（未設定時は下記デフォルト）
# STRIPE_CONNECT_RETURN_URL=https://wanspot.app/events/create?connect=success
# STRIPE_CONNECT_REFRESH_URL=https://wanspot.app/events/create?connect=refresh
#
# 公開サイトオリジン（Checkout の success/cancel URL 用）
# NEXT_PUBLIC_SITE_URL=https://wanspot.app
