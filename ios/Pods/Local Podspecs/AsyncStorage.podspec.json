{
  "name": "AsyncStorage",
  "version": "3.0.2",
  "summary": "Asynchronous, persistent, key-value storage system for React Native.",
  "homepage": "https://github.com/react-native-async-storage/async-storage#readme",
  "license": "MIT",
  "authors": "Krzysztof Borowy <contact@kborowy.com> (https://www.kborowy.com)",
  "platforms": {
    "ios": "13.0",
    "osx": "12.0",
    "visionos": "1.0"
  },
  "source": {
    "git": "https://github.com/react-native-async-storage/async-storage.git",
    "tag": "3.0.2"
  },
  "resource_bundles": {
    "AsyncStorage_resources": "apple/PrivacyInfo.xcprivacy"
  },
  "source_files": "apple/**/*.{h,m,mm,cpp,swift}",
  "swift_versions": "5.9.2",
  "ios": {
    "vendored_frameworks": "apple-frameworks/SharedAsyncStorage.xcframework"
  },
  "osx": {
    "vendored_frameworks": "apple-frameworks/SharedAsyncStorage.xcframework"
  },
  "compiler_flags": "-DRCT_NEW_ARCH_ENABLED=1",
  "dependencies": {
    "React-Core": [],
    "React-RCTFabric": [],
    "ReactCodegen": [],
    "RCTRequired": [],
    "RCTTypeSafety": [],
    "ReactCommon/turbomodule/bridging": [],
    "ReactCommon/turbomodule/core": [],
    "React-NativeModulesApple": [],
    "Yoga": [],
    "React-Fabric": [],
    "React-graphics": [],
    "React-utils": [],
    "React-featureflags": [],
    "React-debug": [],
    "React-ImageManager": [],
    "React-rendererdebug": [],
    "React-jsi": [],
    "React-renderercss": [],
    "hermes-engine": [],
    "ReactNativeDependencies": [],
    "React-Core-prebuilt": []
  },
  "pod_target_xcconfig": {
    "HEADER_SEARCH_PATHS": "\"$(PODS_ROOT)/Headers/Private/Yoga\"",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "OTHER_CPLUSPLUSFLAGS": "$(inherited) -DRCT_NEW_ARCH_ENABLED=1 ",
    "OTHER_SWIFT_FLAGS": "$(inherited) -DRCT_NEW_ARCH_ENABLED"
  },
  "swift_version": "5.9.2"
}
