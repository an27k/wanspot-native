{
  "expo": {
    "name": "wanspot-native",
    "slug": "wanspot-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/wanspot_icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/wanspot_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.wanspot.native",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.wanspot.native",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/wanspot_icon.png",
        "backgroundColor": "#FFD84D"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/images/wanspot_icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "wanspotApiUrl": "",
      "wanspotSiteUrl": "",
      "router": {},
      "eas": {
        "projectId": "8b297e38-b0be-4eb7-86d1-e3f36c90b6f2"
      }
    },
    "owner": "atsu_nemoto"
  }
}
