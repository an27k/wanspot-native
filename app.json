{
  "expo": {
    "name": "wanspot-native",
    "slug": "wanspot-native",
    "version": "1.0.0",
    "jsEngine": "jsc",
    "orientation": "portrait",
    "icon": "./assets/images/wanspot_icon_yellowbg.png",
    "userInterfaceStyle": "light",
    "scheme": "wanspot",
    "splash": {
      "image": "./assets/images/wanspot_image.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.wanspot.native",
      "buildNumber": "91",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "GADNativeAdValidatorEnabled": false,
        "NSPhotoLibraryUsageDescription": "ワンちゃんやプロフィールの写真を設定するため、写真ライブラリへのアクセスを許可してください。",
        "NSCameraUsageDescription": "ワンちゃんやプロフィールの写真を撮影するため、カメラへのアクセスを許可してください。",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "wanspot"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.573139399424-cgqe3u58m724rpjsm5uu0u1t69qor80m"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "app.wanspot.app",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/wanspot_image.png",
        "backgroundColor": "#FFD84D"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/images/wanspot_image.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "近くの散歩エリアの候補を表示するために位置情報を使います。"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-tracking-transparency",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-4709188613454491~3258937977",
          "userTrackingUsageDescription": "パーソナライズされた広告の表示に使用します。"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.573139399424-cgqe3u58m724rpjsm5uu0u1t69qor80m"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ワンちゃんやプロフィールの写真を設定するため、写真ライブラリへのアクセスを許可してください。",
          "cameraPermission": "ワンちゃんやプロフィールの写真を撮影するため、カメラへのアクセスを許可してください。"
        }
      ]
    ],
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "wanspotApiUrl": "",
      "wanspotSiteUrl": "",
      "router": {},
      "eas": {
        "projectId": "8b297e38-b0be-4eb7-86d1-e3f36c90b6f2"
      }
    },
    "owner": "atsu_nemoto"
  },
  "react-native-google-mobile-ads": {
    "android_app_id": "ca-app-pub-3940256099942544~3347511713",
    "ios_app_id": "ca-app-pub-4709188613454491~3258937977",
    "user_tracking_usage_description": "パーソナライズされた広告の表示に使用します。"
  }
}
